# ── Application ───────────────────────────────────────────────
APP_NAME="NeoRAG"
APP_VERSION="1.0.0"
DEBUG=true
# "dev" allows the insecure default SECRET_KEY below; any other value
# requires SECRET_KEY to be explicitly set to a 32+ char random string.
ENV=dev
SECRET_KEY=change-me-to-32-plus-chars-generated-via-openssl-rand-hex-32

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Neo4j Graph Database ───────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ── PostgreSQL (auth user store) ────────────────────────────────
DATABASE_URL=postgresql://neorag:neorag@localhost:5432/neorag

# ── Redis (provisioned for future async/background-task use) ────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant Vector DB ───────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── HuggingFace / LLM ─────────────────────────────────────────
# Get token at: huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# LLM Model — facebook/opt-1.3b needs no token and runs on CPU.
# Swap for a gated model like Llama 3.2 if you have HF access + a token.
LLM_MODEL_NAME=facebook/opt-1.3b
LLM_FALLBACK_MODEL=facebook/opt-1.3b

# NER Model
NER_MODEL=dbmdz/bert-large-cased-finetuned-conll03-english

# Sentiment Analysis Model
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# ── JWT Auth ───────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
