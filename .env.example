# ── Application ───────────────────────────────────────────────
APP_NAME="NeoRAG"
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY="your-secret-key-change-in-production"

# ── Neo4j Graph Database ───────────────────────────────────────
# Run locally: docker run -p 7474:7474 -p 7687:7687 neo4j:latest
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# ── PostgreSQL ─────────────────────────────────────────────────
# Run locally: docker-compose up postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/neorag"

# ── Redis (Celery broker) ──────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── HuggingFace / LLM ─────────────────────────────────────────
# Get token at: huggingface.co/settings/tokens
HUGGINGFACE_TOKEN="hf_your_token_here"

# LLM Model — Llama 3.2 (requires HF token + access)
# Fallback: "facebook/opt-1.3b" (no token needed, lighter)
LLM_MODEL_NAME="meta-llama/Llama-3.2-3B-Instruct"
LLM_FALLBACK_MODEL="facebook/opt-1.3b"

# NER Model (Stanford NLP equivalent via HuggingFace)
NER_MODEL="dbmdz/bert-large-cased-finetuned-conll03-english"

# Sentiment Analysis Model
SENTIMENT_MODEL="cardiffnlp/twitter-roberta-base-sentiment-latest"

# ── Qdrant Vector DB ───────────────────────────────────────────
QDRANT_HOST="localhost"
QDRANT_PORT=6333

# ── JWT Auth ───────────────────────────────────────────────────
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
